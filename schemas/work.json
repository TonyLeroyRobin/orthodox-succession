{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orthodox-succession.org/schemas/work.json",
  "title": "Work",
  "description": "One Work, many Editions — never a second Work record for a translation or reprint. author is a person id when the author is in the database; author_display is a free-text fallback for external authors of works ABOUT a bishop.",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "defs.json#/$defs/workId"
    },
    "title": {
      "type": "string"
    },
    "author": {
      "$ref": "defs.json#/$defs/personId"
    },
    "author_display": {
      "type": "string"
    },
    "subject_of": {
      "type": "array",
      "items": {
        "$ref": "defs.json#/$defs/personId"
      },
      "description": "for works ABOUT a bishop"
    },
    "relation": {
      "enum": [
        "by",
        "about",
        "involving"
      ]
    },
    "language": {
      "type": "string"
    },
    "date": {
      "$ref": "defs.json#/$defs/date"
    },
    "attribution": {
      "enum": [
        "authentic",
        "disputed",
        "spurious"
      ]
    },
    "cpg": {
      "type": "string",
      "description": "Clavis Patrum Graecorum number, e.g. \"CPG 3745\""
    },
    "genre": {
      "enum": [
        "homily",
        "letter",
        "treatise",
        "canon",
        "encyclical",
        "liturgical",
        "hagiography",
        "biography",
        "acts",
        "study",
        "poetry",
        "tomos",
        "synodal-act"
      ]
    },
    "survival": {
      "enum": [
        "extant",
        "fragmentary",
        "lost",
        "extant-in-translation-only"
      ],
      "description": "P4: absence means not-yet-assessed; set extant only when actually verified as such. Lost and fragmentary works are first-class records — absence is information."
    },
    "survival_note": {
      "type": "string",
      "description": "e.g. 'complete only in Latin; Greek fragments'"
    },
    "preserved_in": {
      "type": "array",
      "items": {
        "$ref": "defs.json#/$defs/workId"
      },
      "description": "P4: for fragmentary/lost works surviving as quotations within other works (validate.py: only on fragmentary/lost; referenced works must exist)."
    },
    "editions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "enum": [
              "original",
              "translation"
            ]
          },
          "language": {
            "type": "string"
          },
          "translator": {
            "type": "string"
          },
          "series": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "locator": {
            "type": "string",
            "description": "e.g. \"PG 48:623–692\""
          },
          "url": {
            "type": "string"
          },
          "archived_url": {
            "type": "string",
            "description": "P4: mandatory when url is present — the same archive rule as sources (validate.py, error level)"
          },
          "rights": {
            "enum": [
              "public-domain",
              "in-copyright"
            ]
          },
          "notes": {
            "type": "string"
          },
          "identifiers": {
            "description": "Q4: bibliographic identifiers for find-this-edition links.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "isbn": {
                "type": "string"
              },
              "oclc": {
                "type": "string"
              },
              "worldcat": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "type",
          "language",
          "rights"
        ],
        "additionalProperties": false
      }
    },
    "sources": {
      "$ref": "defs.json#/$defs/sources"
    },
    "status": {
      "$ref": "defs.json#/$defs/status"
    },
    "notes": {
      "type": "string"
    },
    "controversies": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "pattern": "^controversy/[a-z0-9-]+$"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^controversy/[a-z0-9-]+$"
              },
              "note": {
                "type": "string"
              },
              "sources": {
                "$ref": "defs.json#/$defs/sources"
              }
            }
          }
        ]
      }
    },
    "addressee": {
      "description": "C1.1: addressees of letter/encyclical works - correspondence edges are DERIVED from these at build time, never stored as relationships.",
      "type": "array",
      "items": {
        "$ref": "defs.json#/$defs/personId"
      }
    },
    "cites": {
      "description": "C1.2: documented naming/quoting of another work; locator and sources REQUIRED per entry.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "work",
          "locator",
          "sources"
        ],
        "properties": {
          "work": {
            "$ref": "defs.json#/$defs/workId"
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "sources": {
            "$ref": "defs.json#/$defs/sources"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "responds_to": {
      "description": "C1.3: polemical/responsive relation to another work.",
      "type": "array",
      "items": {
        "$ref": "defs.json#/$defs/workId"
      }
    },
    "external": {
      "description": "C1.4: work by an out-of-scope author (no Person record); excluded from Library counts/index by default.",
      "type": "boolean"
    },
    "author_name": {
      "description": "C1.4: plain-text author name for external works.",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "relation",
    "attribution",
    "genre",
    "sources",
    "status"
  ],
  "anyOf": [
    {
      "required": [
        "author"
      ]
    },
    {
      "required": [
        "author_display"
      ]
    },
    {
      "required": [
        "author_name"
      ]
    }
  ],
  "additionalProperties": false
}
