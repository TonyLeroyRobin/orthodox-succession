{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orthodox-succession.org/schemas/jurisdiction.json",
  "title": "Jurisdiction",
  "type": "object",
  "properties": {
    "id": { "$ref": "defs.json#/$defs/jurisdictionId" },
    "name": { "type": "string" },
    "type": { "enum": ["autocephalous", "autonomous", "historical"] },
    "autocephaly": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "granted_by": {
            "type": "string",
            "description": "jurisdiction id, event id (e.g. a council), or free text where neither exists as a record"
          },
          "date": { "$ref": "defs.json#/$defs/date" },
          "recognition": { "$ref": "defs.json#/$defs/recognition" }
        },
        "required": ["granted_by", "date"],
        "additionalProperties": false
      }
    },
    "dissolved": {
      "type": "object",
      "properties": {
        "date": { "$ref": "defs.json#/$defs/date" },
        "successor": {
          "anyOf": [
            { "$ref": "defs.json#/$defs/jurisdictionId" },
            { "const": "none-in-scope",
              "description": "explicit sentinel: the continuing line falls outside this database's scope (DATA_COMPLETION §2) — distinct from an omitted (unknown) successor" }
          ]
        }
      },
      "additionalProperties": false
    },
    "primatial_see": { "$ref": "defs.json#/$defs/seeId" },
    "sources": { "$ref": "defs.json#/$defs/sources" },
    "status": { "$ref": "defs.json#/$defs/status" },
    "notes": { "type": "string" }
  },
  "required": ["id", "name", "type", "sources", "status"],
  "additionalProperties": false
}
