{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orthodox-succession.org/schemas/event.json",
  "title": "Event",
  "description": "Councils, synods, and curated context events. Context events: hard ceiling 300, one-sentence description, one source link (Wikipedia acceptable for this layer only), scope required. They render as a timeline background band, never as graph nodes.",
  "type": "object",
  "properties": {
    "id": { "$ref": "defs.json#/$defs/eventId" },
    "type": { "enum": ["council-ecumenical", "council-local", "synod", "context"] },
    "title": { "type": "string" },
    "date": { "$ref": "defs.json#/$defs/dateRange" },
    "place": { "$ref": "defs.json#/$defs/place" },
    "scope": {
      "type": "string",
      "pattern": "^(global|jurisdiction:jurisdiction/[a-z0-9-]+)$",
      "description": "context events only"
    },
    "description": { "type": "string", "description": "one sentence for context events" },
    "outcomes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "affected": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(see/[a-z0-9-]+/[a-z0-9-]+|jurisdiction/[a-z0-9-]+)$"
      }
    },
    "recognition": { "$ref": "defs.json#/$defs/recognition" },
    "sources": { "$ref": "defs.json#/$defs/sources" },
    "status": { "$ref": "defs.json#/$defs/status" },
    "notes": { "type": "string" }
  },
  "required": ["id", "type", "title", "date", "sources", "status"],
  "if": { "properties": { "type": { "const": "context" } } },
  "then": { "required": ["scope", "description"] },
  "additionalProperties": false
}
