{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orthodox-succession.org/schemas/event.json",
  "title": "Event",
  "description": "Councils, synods, and curated context events. Context events: hard ceiling 300, one-sentence description, one source link (Wikipedia acceptable for this layer only), scope required. They render as a timeline background band, never as graph nodes.",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "defs.json#/$defs/eventId"
    },
    "type": {
      "enum": [
        "council-ecumenical",
        "council-local",
        "synod",
        "context"
      ]
    },
    "title": {
      "type": "string"
    },
    "date": {
      "$ref": "defs.json#/$defs/dateRange"
    },
    "place": {
      "$ref": "defs.json#/$defs/place"
    },
    "scope": {
      "type": "string",
      "pattern": "^(global|jurisdiction:jurisdiction/[a-z0-9-]+)$",
      "description": "context events only"
    },
    "description": {
      "type": "string",
      "description": "one sentence for context events"
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(see/[a-z0-9-]+/[a-z0-9-]+|jurisdiction/[a-z0-9-]+)$"
      }
    },
    "canonical_reception": {
      "enum": [
        "received-universally",
        "received-locally",
        "historical-only",
        "condemned"
      ],
      "description": "R5: how Orthodoxy receives the council's acts/canons. Council types only (validate.py enforces). Recorded, never adjudicated - nuance goes in reception_note."
    },
    "reception_note": {
      "type": "string",
      "description": "e.g. 'canons received via Quinisext canon 2'; pair with canonical_reception"
    },
    "related_works": {
      "type": "array",
      "items": {
        "$ref": "defs.json#/$defs/workId"
      },
      "description": "R5: works produced by or defining for the council (Tome of Leo <-> Chalcedon). Council types only; refs validated."
    },
    "recognition": {
      "$ref": "defs.json#/$defs/recognition"
    },
    "sources": {
      "$ref": "defs.json#/$defs/sources"
    },
    "status": {
      "$ref": "defs.json#/$defs/status"
    },
    "notes": {
      "type": "string"
    },
    "controversies": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "pattern": "^controversy/[a-z0-9-]+$"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^controversy/[a-z0-9-]+$"
              },
              "note": {
                "type": "string"
              },
              "sources": {
                "$ref": "defs.json#/$defs/sources"
              }
            }
          }
        ]
      }
    }
  },
  "required": [
    "id",
    "type",
    "title",
    "date",
    "sources",
    "status"
  ],
  "if": {
    "properties": {
      "type": {
        "const": "context"
      }
    }
  },
  "then": {
    "required": [
      "scope",
      "description"
    ]
  },
  "additionalProperties": false
}
